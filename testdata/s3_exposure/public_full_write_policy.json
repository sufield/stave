{
  "buckets": [
    {
      "name": "public-full-write-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:PutObject", "s3:GetObject"],
            "assets": [
              "arn:aws:s3:::public-full-write-bucket",
              "arn:aws:s3:::public-full-write-bucket/*"
            ]
          }
        ]
      },
      "acl": { "grants": [] }
    }
  ]
}
