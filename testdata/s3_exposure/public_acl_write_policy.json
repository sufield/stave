{
  "buckets": [
    {
      "name": "acl-writable-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:PutBucketAcl"],
            "assets": ["arn:aws:s3:::acl-writable-bucket"]
          }
        ]
      },
      "acl": { "grants": [] }
    }
  ]
}
