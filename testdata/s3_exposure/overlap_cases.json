{
  "buckets": [
    {
      "name": "policy+acl_read_bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:GetObject"],
            "assets": ["arn:aws:s3:::policy+acl_read_bucket/*"]
          }
        ]
      },
      "acl": {
        "grants": [
          {
            "grantee": "AllUsers",
            "permission": "READ",
            "scope": "object"
          }
        ]
      }
    },
    {
      "name": "policy_read_acl_write_bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:GetObject"],
            "assets": ["arn:aws:s3:::policy_read_acl_write_bucket/*"]
          }
        ]
      },
      "acl": {
        "grants": [
          {
            "grantee": "AllUsers",
            "permission": "WRITE",
            "scope": "object"
          }
        ]
      }
    },
    {
      "name": "full_write_with_list_bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:PutObject", "s3:ListBucket"],
            "assets": [
              "arn:aws:s3:::full_write_with_list_bucket",
              "arn:aws:s3:::full_write_with_list_bucket/*"
            ]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "website_acl_read_bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": true },
      "policy": { "statements": [] },
      "acl": {
        "grants": [
          {
            "grantee": "AllUsers",
            "permission": "READ",
            "scope": "object"
          }
        ]
      }
    },
    {
      "name": "authenticated_write_bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "AWS:AuthenticatedUsers",
            "actions": ["s3:PutObject"],
            "assets": ["arn:aws:s3:::authenticated_write_bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    }
  ]
}
