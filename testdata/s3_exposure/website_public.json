{
  "buckets": [
    {
      "name": "website-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": true },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:GetObject"],
            "resources": ["arn:aws:s3:::website-bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    }
  ]
}
