{
  "buckets": [
    {
      "name": "public-read-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:GetObject"],
            "resources": ["arn:aws:s3:::public-read-bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "public-list-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": { "statements": [] },
      "acl": {
        "grants": [
          {
            "grantee": "AllUsers",
            "permission": "READ",
            "scope": "bucket"
          }
        ]
      }
    },
    {
      "name": "public-write-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:PutObject"],
            "resources": ["arn:aws:s3:::public-write-bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "public-full-write-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:PutObject", "s3:GetObject"],
            "resources": [
              "arn:aws:s3:::public-full-write-bucket",
              "arn:aws:s3:::public-full-write-bucket/*"
            ]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "auth-users-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "AWS:AuthenticatedUsers",
            "actions": ["s3:GetObject"],
            "resources": ["arn:aws:s3:::auth-users-bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "acl-public-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": { "statements": [] },
      "acl": {
        "grants": [
          {
            "grantee": "AllUsers",
            "permission": "READ",
            "scope": "object"
          }
        ]
      }
    },
    {
      "name": "website-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": true },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:GetObject"],
            "resources": ["arn:aws:s3:::website-bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "acl-readable-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:GetBucketAcl"],
            "resources": ["arn:aws:s3:::acl-readable-bucket"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "acl-writable-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:PutBucketAcl"],
            "resources": ["arn:aws:s3:::acl-writable-bucket"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "deletable-bucket",
      "exists": true,
      "external_reference": false,
      "website": { "enabled": false },
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": "*",
            "actions": ["s3:DeleteObject"],
            "resources": ["arn:aws:s3:::deletable-bucket/*"]
          }
        ]
      },
      "acl": { "grants": [] }
    },
    {
      "name": "missing-bucket-ref",
      "exists": false,
      "external_reference": true,
      "website": { "enabled": false },
      "policy": { "statements": [] },
      "acl": { "grants": [] }
    }
  ]
}
