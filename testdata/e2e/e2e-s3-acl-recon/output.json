      "control_id": "CTL.S3.ACL.RECON.001",
      "control_name": "No Public ACL Readability",
      "control_description": "S3 bucket ACLs should not be readable by unauthenticated users. READ_ACP permission enables attackers to enumerate ACL grants, discover which principals have access, and find escalation paths.\n",
      "asset_id": "acl-readable-bucket",
      "asset_type": "aws_s3_bucket",
      "asset_vendor": "aws",
      "evidence": {
        "first_unsafe_at": "2026-01-01T00:00:00Z",
        "last_seen_unsafe_at": "2026-01-11T00:00:00Z",
        "unsafe_duration_hours": 240,
        "threshold_hours": 168,
        "misconfigurations": [
          {
            "property": "storage.visibility.public_admin",
            "actual_value": "[SANITIZED]",
            "operator": "eq",
            "unsafe_value": true
          }
        ],
        "why_now": "Asset has been unsafe for 240 hours (threshold: 168 hours). Unsafe since 2026-01-01T00:00:00Z."
      },
      "posture_drift": {
        "pattern": "persistent",
        "episode_count": 1
      },
      "remediation": {
        "description": "Bucket grants ACL read access (READ_ACP) to public users. An attacker can call GetBucketAcl to discover which principals have access and identify escalation paths.\n",
        "action": "Remove READ_ACP grants from the bucket ACL and remove policy statements granting s3:GetBucketAcl or s3:GetObjectAcl to public principals. Enable S3 Public Access Block with BlockPublicAcls set to true.\n",
        "example": "{\n  \"storage\": {\n    \"visibility\": {\n      \"public_admin\": false\n    }\n  }\n}\n"
      }
    }
