# Verify --quiet and --verbose flags (clig.dev § Verbosity)

# --quiet suppresses non-essential output
exec stave apply --controls controls --observations observations-clean --max-unsafe 168h --now 2026-01-11T00:00:00Z --quiet --format json --allow-unknown-input
! stderr 'No violations'
stdout '"schema_version"'

# --quiet with violations still exits 3
! exec stave apply --controls controls --observations observations --max-unsafe 24h --now 2026-01-11T00:00:00Z --quiet --format json --allow-unknown-input

-- controls/CTL.TEST.001.yaml --
dsl_version: ctrl.v1
id: CTL.TEST.001
name: Test Control
description: Test.
domain: exposure
severity: high
type: unsafe_duration
params:
  max_unsafe_duration: "12h"
unsafe_predicate:
  all:
    - field: properties.public
      op: eq
      value: true

