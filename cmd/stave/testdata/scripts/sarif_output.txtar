# Verify SARIF output format (clig.dev § Machine Readability)

! exec stave apply --controls controls --observations observations --max-unsafe 24h --now 2026-01-11T00:00:00Z --format sarif --allow-unknown-input
stdout 'runs'
stdout 'results'
stdout 'tool'

-- controls/CTL.TEST.001.yaml --
dsl_version: ctrl.v1
id: CTL.TEST.001
name: Test Public Access
description: Bucket must not allow public read.
domain: exposure
severity: high
type: unsafe_duration
params:
  max_unsafe_duration: "12h"
unsafe_predicate:
  all:
    - field: properties.public
      op: eq
      value: true

-- observations/2026-01-09T000000Z.json --
{
  "schema_version": "obs.v0.1",
