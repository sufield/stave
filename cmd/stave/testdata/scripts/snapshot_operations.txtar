# Exercise snapshot subcommands with real data

# Snapshot diff
exec stave snapshot diff --observations observations --format json
stdout 'from_captured'

# Snapshot quality
exec stave snapshot quality --observations observations --now 2026-01-11T00:00:00Z

# Snapshot upcoming
exec stave snapshot upcoming --controls controls --observations observations --now 2026-01-11T00:00:00Z

# Snapshot plan
exec stave snapshot plan --observations-root observations --now 2026-01-11T00:00:00Z

# Snapshot archive dry-run
exec stave snapshot archive --observations observations --archive-dir archive --older-than 1h --now 2026-01-11T00:00:00Z --dry-run

# Snapshot hygiene
exec stave snapshot hygiene --controls controls --observations observations --now 2026-01-11T00:00:00Z

-- controls/CTL.S3.PUBLIC.001.yaml --
dsl_version: ctrl.v1
id: CTL.S3.PUBLIC.001
name: No Public S3 Bucket Read
description: Test.
domain: exposure
severity: critical
type: unsafe_duration
params:
  max_unsafe_duration: "168h"
scope_tags:
  - aws
  - s3
unsafe_predicate:
  all:
    - field: properties.storage.access.public_read
      op: eq
      value: true

-- observations/2026-01-09T000000Z.json --
{
  "schema_version": "obs.v0.1",
  "generated_by": {"source_type": "aws-s3-snapshot", "tool": "stave-extractor"},
  "captured_at": "2026-01-09T00:00:00Z",
  "assets": [{
    "id": "test-bucket",
    "type": "aws_s3_bucket",
    "vendor": "aws",
    "properties": {"storage": {"access": {"public_read": true}}}
  }]
}

